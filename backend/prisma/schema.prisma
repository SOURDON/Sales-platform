generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  DIRECTOR
  MANAGER
  ADMIN
  SELLER
  ACCOUNTANT
  RETOUCHER
}

enum StaffPosition {
  SALES
  RETOUCHER
}

enum CommissionRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DirectorApprovalKind {
  SALE_DELETE
  WRITE_OFF
}

enum DirectorApprovalState {
  PENDING
  APPROVED
  REJECTED
}

enum ManagerIssueCategory {
  PERSONNEL
  INSPECTION
  GOODS
  EQUIPMENT_BREAKDOWN
  NEEDS
}

enum ManagerIssueStatus {
  NEW
  IN_PROGRESS
  DONE
}

enum WriteOffReason {
  BRAK
  POLOMKA
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum PaymentType {
  CASH
  NON_CASH
  TRANSFER
}

enum CashEventType {
  RETURN
  CANCEL
  ADJUSTMENT
}

enum FinanceAccountKind {
  CASH
  BANK
}

model AppState {
  id               Int       @id
  currentShiftId   String?
  lastSaleAt       DateTime?
  acquiringPercent Float     @default(1.8)
  acquiringPercentDetkov Float @default(1.8)
  acquiringPercentPutintsevSber Float @default(1.8)
  updatedAt        DateTime  @updatedAt
}

model FinanceAccount {
  id        String            @id
  name      String
  kind      FinanceAccountKind
  balance   Float
  updatedAt DateTime          @updatedAt
  expenses  FinanceExpense[]
  incomes   FinanceIncome[]
}

model FinanceIncome {
  id          String         @id
  createdAt   DateTime
  workDay     String
  accountId   String
  accountName String
  amount      Float
  comment     String?
  createdBy   String
  account     FinanceAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model FinanceExpense {
  id          String        @id
  createdAt   DateTime
  title       String
  amount      Float
  comment     String?
  createdBy   String
  accountId   String
  accountName String
  account     FinanceAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model User {
  id         Int           @id
  nickname   String        @unique
  password   String
  fullName   String
  role       UserRole
  storeName  String
  isActive   Boolean       @default(true)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  profile    SellerProfile?
  staff      StaffMember?
}

model SellerProfile {
  id         Int      @id
  user       User     @relation(fields: [id], references: [id], onDelete: Cascade)
  storeName  String
  ratePercent Float
  sales      Sale[]
}

model Sale {
  id            String         @id
  createdAt     DateTime
  totalAmount   Float
  units         Int
  paymentType   PaymentType    @default(CASH)
  sellerId      Int
  seller        SellerProfile  @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  items         SaleItem[]
}

model SaleItem {
  id       String @id
  saleId   String
  name     String
  qty      Int
  sale     Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model WriteOff {
  id        String         @id
  createdAt DateTime
  name      String
  qty       Int
  reason    WriteOffReason
}

model Shift {
  id             String      @id
  openedAt       DateTime
  closedAt       DateTime?
  openedBy       String
  closedBy       String?
  checksCount    Int
  itemsCount     Int
  status         ShiftStatus
  assignedSellers ShiftAssignment[]
}

model ShiftAssignment {
  shiftId   String
  sellerId  Int
  shift     Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@id([shiftId, sellerId])
}

model CashDisciplineEvent {
  id        String       @id
  createdAt DateTime
  type      CashEventType
  comment   String
  createdBy String
}

model StaffMember {
  id                   Int           @id
  user                 User          @relation(fields: [id], references: [id], onDelete: Cascade)
  fullName             String
  nickname             String        @unique
  isActive             Boolean       @default(true)
  assignedShiftId      String?
  staffPosition        StaffPosition @default(SALES)
  /** Доля от выручки точки за календарный день (используется для позиции RETOUCHER). */
  retoucherRatePercent Float         @default(5)
  assignments          StoreStaffAssignment[]
}

model StoreStaffAssignment {
  storeName String
  staffId   Int
  staff     StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@id([storeName, staffId])
}

model ProductCatalog {
  name  String @id
  price Float
}

/// Остатки по локации: `CENTRAL_WAREHOUSE_LOCATION_KEY` — центральный склад; иначе — `storeName` точки.
model ProductStockLocation {
  locationKey String
  productName String
  qty         Int
  @@id([locationKey, productName])
  @@index([locationKey])
}

model ProductProcurementCost {
  name String @id
  cost Float
}

model StoreRevenuePlan {
  dayKey     String
  storeName  String
  planRevenue Float

  @@id([dayKey, storeName])
}

model CommissionChangeRequest {
  id                 String                  @id
  createdAt          DateTime
  sellerId           Int
  requestedByNickname String
  requestedPercent   Float
  previousPercent    Float
  status             CommissionRequestStatus
  comment            String?
}

model DirectorApprovalRequest {
  id                   String               @id
  createdAt            DateTime             @default(now())
  kind                 DirectorApprovalKind
  state                DirectorApprovalState @default(PENDING)
  requestedByNickname  String
  storeName            String
  payload              Json
  resolvedAt           DateTime?
  resolvedBy           String?
}

model ManagerIssue {
  id               String               @id
  createdAt        DateTime             @default(now())
  storeName        String
  createdByNickname String
  category         ManagerIssueCategory
  message          String
  status           ManagerIssueStatus   @default(NEW)
  startedAt        DateTime?
  startedBy        String?
  completedAt      DateTime?
  completedBy      String?
}

model AuditLogItem {
  id        String @id
  createdAt DateTime
  actor     String
  action    String
  details   String
}
