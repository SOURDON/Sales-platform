PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public
# После заполнения DATABASE_URL: npm run db:sync — миграции + безопасный сид (без удаления данных).
# Comma-separated list of allowed origins for browser requests.
# Example: https://sales-platform.vercel.app,https://admin.example.com
CORS_ORIGIN=http://localhost:5173
